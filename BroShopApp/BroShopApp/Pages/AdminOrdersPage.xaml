<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BroShopApp.Pages.AdminOrdersPage"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="Black"
             x:Name="AdminPage">

    <Grid>
        <Image Source="background.jpg" Aspect="AspectFill" Opacity="0.3" />

        <Grid RowDefinitions="Auto, Auto, *" Margin="20,40,20,0">

            <HorizontalStackLayout Grid.Row="0" Spacing="15" VerticalOptions="Center" Margin="0,0,0,20">
                <Border StrokeShape="RoundRectangle 15" BackgroundColor="#40000000" HeightRequest="40" WidthRequest="40" StrokeThickness="0">
                    <ImageButton Source="back_icon.png" Padding="10" Clicked="OnBackClicked" BackgroundColor="Transparent"/>
                </Border>
                <Label Text="УПРАВЛЕНИЕ ЗАКАЗАМИ" TextColor="White" FontSize="22" FontAttributes="Bold" VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <Border Grid.Row="1" StrokeShape="RoundRectangle 15" Stroke="#30FFFFFF" BackgroundColor="#15FFFFFF" Margin="0,0,0,20" HeightRequest="50">
                <SearchBar x:Name="OrderSearchBar" 
                           Placeholder="Поиск по номеру или клиенту..." 
                           PlaceholderColor="#80FFFFFF"
                           TextColor="White"
                           CancelButtonColor="White"
                           TextChanged="OnSearchTextChanged" />
            </Border>

            <RefreshView Grid.Row="2" x:Name="OrdersRefreshView" Refreshing="OnRefreshing">
                <CollectionView x:Name="OrdersCollectionView" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,15" Padding="20" StrokeShape="RoundRectangle 25" Stroke="#20FFFFFF" BackgroundColor="#15FFFFFF">
                                <VerticalStackLayout Spacing="10">

                                    <Grid ColumnDefinitions="*, Auto">
                                        <Label Text="{Binding OrderId, StringFormat='Заказ #{0}'}" TextColor="White" FontSize="18" FontAttributes="Bold"/>
                                        <Label Grid.Column="1" Text="{Binding DisplayDate}" TextColor="#80FFFFFF" FontSize="12" VerticalOptions="Center"/>
                                    </Grid>

                                    <HorizontalStackLayout Spacing="10">
                                        <Label Text="Клиент:" TextColor="#AAAAAA" FontSize="14"/>
                                        <Label Text="{Binding UserName}" TextColor="White" FontSize="14" FontAttributes="Bold"/>
                                    </HorizontalStackLayout>

                                    <HorizontalStackLayout Spacing="10">
                                        <Label Text="Адрес:" TextColor="#AAAAAA" FontSize="14"/>
                                        <Label Text="{Binding Address}" TextColor="White" FontSize="14" LineBreakMode="TailTruncation"/>
                                    </HorizontalStackLayout>

                                    <HorizontalStackLayout Spacing="10">
                                        <Label Text="Сумма:" TextColor="#AAAAAA" FontSize="14"/>
                                        <Label Text="{Binding DisplayTotal}" TextColor="#4CAF50" FontSize="16" FontAttributes="Bold"/>
                                    </HorizontalStackLayout>

                                    <BoxView HeightRequest="1" BackgroundColor="#20FFFFFF" Margin="0,5"/>

                                    <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10">
                                        <Border StrokeShape="RoundRectangle 12" BackgroundColor="#1A1A1A" Stroke="#30FFFFFF">
                                            <Picker ItemsSource="{Binding Source={x:Reference AdminPage}, Path=AvailableStatuses}"
                                                    SelectedItem="{Binding Status}"
                                                    TextColor="White"
                                                    Title="Статус"
                                                    Margin="10,0" />
                                        </Border>

                                        <Button Grid.Column="1" 
                                                Text="СОХРАНИТЬ" 
                                                BackgroundColor="White" 
                                                TextColor="Black" 
                                                FontAttributes="Bold" 
                                                CornerRadius="12" 
                                                CommandParameter="{Binding .}"
                                                Clicked="OnSaveStatusClicked"/>
                                    </Grid>

                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </RefreshView>
        </Grid>
    </Grid>
</ContentPage>