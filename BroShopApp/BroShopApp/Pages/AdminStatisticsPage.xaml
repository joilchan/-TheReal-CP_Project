<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BroShopApp.Pages.AdminStatisticsPage"
             Title="Учет и статистика"
             Shell.NavBarIsVisible="False"
             BackgroundColor="Black">

    <Grid>
        <Image Source="background.jpg" Aspect="AspectFill" Opacity="0.3"/>

        <VerticalStackLayout Padding="20" Spacing="20">

            <Label Text="ОБЩАЯ СТАТИСТИКА МАГАЗИНА" 
                   TextColor="Gray" 
                   FontSize="14" 
                   CharacterSpacing="2"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   Margin="0,10,0,10"/>

            <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="*, *" RowSpacing="15" ColumnSpacing="15">

                <Border Grid.Row="0" Grid.Column="0" StrokeShape="RoundRectangle 15" BackgroundColor="#1AFFFFFF" Padding="15">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Выручка" TextColor="Gray" FontSize="12"/>
                        <Label Text="{Binding DisplayRevenue}" TextColor="#A6FF00" FontSize="20" FontAttributes="Bold"/>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="0" Grid.Column="1" StrokeShape="RoundRectangle 15" BackgroundColor="#1AFFFFFF" Padding="15">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Всего заказов" TextColor="Gray" FontSize="12"/>
                        <Label Text="{Binding TotalOrders}" TextColor="White" FontSize="20" FontAttributes="Bold"/>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="1" Grid.Column="0" StrokeShape="RoundRectangle 15" BackgroundColor="#1AFFFFFF" Padding="15">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Клиентов" TextColor="Gray" FontSize="12"/>
                        <Label Text="{Binding TotalUsers}" TextColor="White" FontSize="20" FontAttributes="Bold"/>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="1" Grid.Column="1" StrokeShape="RoundRectangle 15" BackgroundColor="#40FF4444" Padding="15" Stroke="#80FF4444">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Новые заказы" TextColor="#FFDDDD" FontSize="12"/>
                        <Label Text="{Binding PendingOrders}" TextColor="White" FontSize="20" FontAttributes="Bold"/>
                    </VerticalStackLayout>
                </Border>

            </Grid>

            <Button Text="ВЕРНУТЬСЯ" 
                    Clicked="OnBackClicked" 
                    BackgroundColor="White" 
                    TextColor="Black" 
                    CornerRadius="25" 
                    HeightRequest="50" 
                    FontAttributes="Bold"
                    Margin="0,30,0,0"/>
        </VerticalStackLayout>
    </Grid>
</ContentPage>