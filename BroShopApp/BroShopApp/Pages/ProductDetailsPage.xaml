<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:BroShopApp.Model"
             xmlns:pages="clr-namespace:BroShopApp.Pages"
             x:Class="BroShopApp.Pages.ProductDetailsPage"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="Black">

    <Grid>
        <Image Source="background.jpg" Aspect="AspectFill" />

        <Grid RowDefinitions="Auto, *">
            <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">
                <Grid RowDefinitions="Auto, Auto">
                    
                    <Image Grid.Row="0"
                           Source="{Binding ImageUrl}" 
                           Aspect="AspectFill"
                           HeightRequest="500" 
                           HorizontalOptions="Fill"
                           VerticalOptions="Start"/>

                    <Border Grid.Row="1" 
                            Margin="0,-60,0,0" 
                            Padding="25,35,25,40" 
                            StrokeShape="RoundRectangle 40,40,0,0" 
                            Stroke="Transparent"
                            BackgroundColor="#FF1A1A1A">
                        <VerticalStackLayout Spacing="16">

                            <VerticalStackLayout Spacing="2">
                                <Label Text="{Binding Brand.Name}" TextColor="#AAAAAA" FontSize="12" FontAttributes="Bold" TextTransform="Uppercase"/>
                                <Label Text="{Binding Name}" TextColor="White" FontSize="28" FontAttributes="Bold"/>
                                <Label Text="{Binding Price, StringFormat='{0:N0} ₽'}" TextColor="White" FontSize="24" FontAttributes="Bold" Margin="0,5,0,0"/>
                            </VerticalStackLayout>
                            
                            <VerticalStackLayout IsVisible="{Binding IsSizeVisible, Source={RelativeSource AncestorType={x:Type pages:ProductDetailsPage}}}">
                                <Label Text="Размер" 
                                           TextColor="White" 
                                           FontSize="18" 
                                           FontAttributes="Bold" 
                                           Margin="0,10,0,5"/>

                                    <CollectionView ItemsSource="{Binding ProductVariants}" 
                                                    x:Name="SizeCollectionView"
                                                    SelectionMode="Single"
                                                    HeightRequest="50"
                                                    IsVisible="{Binding ProductVariants.Count, Converter={StaticResource NotZeroConverter}}"
                                                    SelectionChanged="OnSizeSelectionChanged">
                                        <CollectionView.ItemsLayout>
                                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10"/>
                                        </CollectionView.ItemsLayout>
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate>
                                                <Border StrokeShape="RoundRectangle 12" 
                                                        Padding="15,0" 
                                                        HeightRequest="45">

                                                    <VisualStateManager.VisualStateGroups>
                                                        <VisualStateGroup Name="CommonStates">
                                                            <VisualState Name="Normal">
                                                                <VisualState.Setters>
                                                                    <Setter Property="BackgroundColor" Value="#20FFFFFF" />
                                                                    <Setter Property="Stroke" Value="#40FFFFFF" />
                                                                </VisualState.Setters>
                                                            </VisualState>
                                                            <VisualState Name="Selected">
                                                                <VisualState.Setters>
                                                                    <Setter Property="BackgroundColor" Value="#66FFFFFF" />
                                                                    <Setter Property="Stroke" Value="White" />
                                                                </VisualState.Setters>
                                                            </VisualState>
                                                        </VisualStateGroup>
                                                    </VisualStateManager.VisualStateGroups>

                                                    <Label Text="{Binding Size}" 
                                                           TextColor="White" 
                                                           VerticalOptions="Center" 
                                                           HorizontalOptions="Center" 
                                                           FontAttributes="Bold" 
                                                           FontSize="14"/>
                                                </Border>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="8">
                                <Label Text="Описание" TextColor="White" FontSize="16" FontAttributes="Bold" Opacity="0.9"/>
                                <Label Text="{Binding Description}" TextColor="#BBFFFFFF" FontSize="15" LineHeight="1.4"/>
                            </VerticalStackLayout>

                            <Button Text="ДОБАВИТЬ В КОРЗИНУ" 
          BackgroundColor="White" 
          TextColor="Black" 
          FontAttributes="Bold" 
          CornerRadius="18" 
          HeightRequest="60" 
          Margin="0,10,0,0" 
          Clicked="OnAddToCartClicked"/>

                            <BoxView HeightRequest="1" BackgroundColor="#20FFFFFF" Margin="0,10"/>

                            <Label Text="Отзывы" TextColor="White" FontSize="18" FontAttributes="Bold"/>

                            <Border x:Name="ReviewSection" IsVisible="False" StrokeShape="RoundRectangle 20" BackgroundColor="#10FFFFFF" Padding="20" Stroke="#20FFFFFF">
                                <VerticalStackLayout Spacing="15">
                                    <Editor x:Name="ReviewEditor" Placeholder="Поделитесь впечатлениями..." 
                  AutoSize="TextChanges" TextColor="White" PlaceholderColor="#60FFFFFF"/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                                            <Label Text="Оценка:" TextColor="Gray" VerticalOptions="Center"/>
                                            <Entry x:Name="RatingEntry" Text="5" Keyboard="Numeric" WidthRequest="40" TextColor="White" HorizontalTextAlignment="Center"/>
                                        </HorizontalStackLayout>
                                        <Button Grid.Column="1" Text="ОТПРАВИТЬ" Clicked="OnSendReviewClicked" 
                      BackgroundColor="White" TextColor="Black" CornerRadius="10" HeightRequest="40" Padding="15,0"/>
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>

                            <Border x:Name="GuestSection" StrokeShape="RoundRectangle 15" Stroke="#20FFFFFF" BackgroundColor="Transparent" Padding="15">
                                <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                                    <Label Text="Хотите оставить отзыв?" TextColor="#80FFFFFF" VerticalOptions="Center"/>
                                    <Button Text="Войти" Clicked="OnLoginRedirectClicked" TextColor="White" FontAttributes="Bold" 
                  BackgroundColor="Transparent" Padding="0" HeightRequest="30"/>
                                </HorizontalStackLayout>
                            </Border>

                            <CollectionView ItemsSource="{Binding Reviews}">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,12" Padding="15" StrokeShape="RoundRectangle 20" Stroke="Transparent" BackgroundColor="#08FFFFFF">
                                            <VerticalStackLayout Spacing="6">
                                                <Grid ColumnDefinitions="Auto, *">
                                                    <HorizontalStackLayout Spacing="4">
                                                        <Label Text="⭐" FontSize="12" VerticalOptions="Center"/>
                                                        <Label Text="{Binding Rating}" TextColor="White" FontAttributes="Bold" VerticalOptions="Center"/>
                                                    </HorizontalStackLayout>
                                                    <Label Grid.Column="1" Text="{Binding UserLogin}" TextColor="#60FFFFFF" FontSize="13" HorizontalOptions="End" VerticalOptions="Center"/>
                                                </Grid>
                                                <Label Text="{Binding Text}" TextColor="#CCFFFFFF" FontSize="14" LineHeight="1.2"/>
                                            </VerticalStackLayout>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </Border>
                </Grid>
            </ScrollView>
        </Grid>

        <Border StrokeShape="RoundRectangle 20" 
            BackgroundColor="#30000000" 
            HeightRequest="40" 
            WidthRequest="40" 
            HorizontalOptions="Start" 
            VerticalOptions="Start" 
            Margin="15,40" 
            StrokeThickness="0">    
            <ImageButton Source="back_icon.png" Padding="10" Clicked="OnBackClicked" BackgroundColor="Transparent"/>
        </Border>
    </Grid>
</ContentPage>