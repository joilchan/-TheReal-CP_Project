<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:BroShopApp.Model"
             x:Class="BroShopApp.Pages.ProfilePage"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             xmlns:converters="clr-namespace:BroShopApp.Converters">
    <ContentPage.Resources>
        <converters:StatusToColorConverter x:Key="StatusToColor" />
    </ContentPage.Resources>

    <Grid>
        <Image Source="background.jpg" Aspect="AspectFill" Opacity="0.7" />

        <ScrollView VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Padding="20, 40, 20, 30" Spacing="25">

                <VerticalStackLayout Spacing="10" HorizontalOptions="Center" Margin="0,0,0,10">
                    <Border StrokeShape="RoundRectangle 60" 
                            HeightRequest="120" 
                            WidthRequest="120" 
                            Stroke="#40FFFFFF" 
                            StrokeThickness="2"
                            BackgroundColor="#15FFFFFF">
                        <Image Source="user_icon.png" Aspect="AspectFit" Margin="25"/>
                    </Border>
                    <Label x:Name="NameHeaderLabel" 
                           TextColor="White" 
                           FontSize="24" 
                           FontAttributes="Bold" 
                           HorizontalOptions="Center"/>
                    <Label Text="Постоянный покупатель" 
                           TextColor="#80FFFFFF" 
                           FontSize="12" 
                           CharacterSpacing="1"
                           HorizontalOptions="Center" 
                           TextTransform="Uppercase"/>
                </VerticalStackLayout>

                <Label Text="ЛИЧНЫЕ ДАННЫЕ" TextColor="#80FFFFFF" FontSize="12" CharacterSpacing="2" Margin="5,0"/>
                <Border StrokeShape="RoundRectangle 20" Stroke="#30FFFFFF" BackgroundColor="#15FFFFFF" Padding="20">
                    <VerticalStackLayout Spacing="15">
                        <Grid ColumnDefinitions="100, *">
                            <Label Text="Имя" TextColor="#60FFFFFF" FontSize="14" VerticalOptions="Center"/>
                            <Label Grid.Column="1" x:Name="NameLabel" TextColor="White" FontSize="16" FontAttributes="Bold" HorizontalOptions="End"/>
                        </Grid>
                        <BoxView HeightRequest="1" BackgroundColor="#10FFFFFF"/>
                        <Grid ColumnDefinitions="100, *">
                            <Label Text="Логин" TextColor="#60FFFFFF" FontSize="14" VerticalOptions="Center"/>
                            <Label Grid.Column="1" x:Name="LoginLabel" TextColor="White" FontSize="16" HorizontalOptions="End"/>
                        </Grid>
                        <BoxView HeightRequest="1" BackgroundColor="#10FFFFFF"/>
                        <Grid ColumnDefinitions="100, *">
                            <Label Text="Email" TextColor="#60FFFFFF" FontSize="14" VerticalOptions="Center"/>
                            <Label Grid.Column="1" x:Name="EmailLabel" TextColor="White" FontSize="16" HorizontalOptions="End"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Grid ColumnDefinitions="*, Auto" Margin="5,10,5,0">
                    <Label Text="ИСТОРИЯ ЗАКАЗОВ" TextColor="#80FFFFFF" FontSize="12" CharacterSpacing="2"/>
                    <Label Grid.Column="1" Text="Всего: 0" x:Name="OrdersCountLabel" TextColor="#60FFFFFF" FontSize="12"/>
                </Grid>

                <CollectionView x:Name="OrdersCollection" 
                                SelectionMode="Single"
                                SelectionChanged="OnOrderSelected">
                    <CollectionView.EmptyView>
                        <VerticalStackLayout HorizontalOptions="Center" Margin="0,30">
                            <Image Source="empty_cart.png" HeightRequest="60" Opacity="0.3"/>
                            <Label Text="Заказов пока нет" TextColor="#40FFFFFF" HorizontalOptions="Center" Margin="0,10"/>
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="12"/>
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Order">
                            <Border StrokeShape="RoundRectangle 18" 
                                    Stroke="#20FFFFFF" 
                                    BackgroundColor="#10FFFFFF" 
                                    Padding="15" 
                                    Margin="0,0,0,10">
                                <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="*, Auto, Auto">

                                    <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="2">
                                        <Label Text="{Binding DisplayDate}" TextColor="#60FFFFFF" FontSize="11"/>
                                        <Label Text="{Binding Address}" TextColor="White" FontSize="14" FontAttributes="Bold" LineBreakMode="TailTruncation"/>
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Grid.Row="0" Grid.Column="1">
                                        <ImageButton
                                                 Margin="45, 0, 0, 0"
                                                 Source="close_icon.png" 
                                                 HeightRequest="20" 
                                                 WidthRequest="20"
                                                 Padding="2"
                                                 BackgroundColor="Transparent"
                                                 VerticalOptions="Start"
                                                 IsVisible="{Binding Status, Converter={StaticResource StatusToCancelVisible}}"
                                                 Clicked="OnCancelOrderClicked"
                                                 CommandParameter="{Binding .}">
                                        </ImageButton>
                                    </VerticalStackLayout>
                                    

                                    <Label Grid.Row="1"
                                           Text="{Binding DisplayTotal}" 
                                           TextColor="White" 
                                           FontSize="18" 
                                           FontAttributes="Bold" 
                                           Margin="0,12,0,0"/>

                                    <Border Grid.Row="1" Grid.Column="1"
                                            StrokeShape="RoundRectangle 8" 
                                            BackgroundColor="{Binding Status, Converter={StaticResource StatusToColor}, ConverterParameter='BG'}" 
                                            Padding="8,4" 
                                            VerticalOptions="Start"
                                            HorizontalOptions="End"
                                            Margin="0, 10, 0, 0">
                                        <Label Text="{Binding Status}" 
                                                   TextColor="{Binding Status, Converter={StaticResource StatusToColor}}" 
                                                   FontSize="10" FontAttributes="Bold"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                        </CollectionView.ItemTemplate>
                </CollectionView>

                <Button Text="ВЫЙТИ ИЗ АККАУНТА" 
                        Clicked="OnLogoutClicked"
                        BackgroundColor="Transparent" 
                        TextColor="#FF4444" 
                        BorderColor="#40FF4444" 
                        BorderWidth="1"
                        FontAttributes="Bold" 
                        CornerRadius="15" 
                        HeightRequest="50" 
                        Margin="0,20,0,20"/>

            </VerticalStackLayout>
        </ScrollView>

        <Border StrokeShape="RoundRectangle 20" 
                BackgroundColor="#30000000" 
                HeightRequest="40" 
                WidthRequest="40" 
                HorizontalOptions="Start" 
                VerticalOptions="Start" 
                Margin="15,40" 
                StrokeThickness="0">
            <ImageButton Source="back_icon.png" Padding="10" Clicked="OnBackClicked" BackgroundColor="Transparent"/>
        </Border>
    </Grid>
</ContentPage>