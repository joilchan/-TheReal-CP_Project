<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:BroShopApp.Model"
             x:Class="BroShopApp.Pages.ProfilePage"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="Black">

    <Grid>
        <Image Source="background.jpg" Aspect="AspectFill" />

        <VerticalStackLayout Padding="30" Spacing="20" VerticalOptions="Center">

            <Image Source="user_icon.png" HeightRequest="100" HorizontalOptions="Center" Margin="0,0,0,20"/>

            <Border StrokeShape="RoundRectangle 25" Stroke="#30FFFFFF" BackgroundColor="#1AFFFFFF" Padding="25">
                <VerticalStackLayout Spacing="15">
                    <Label Text="ПРОФИЛЬ" TextColor="White" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center" Margin="0,0,0,10"/>

                    <HorizontalStackLayout Spacing="10">
                        <Label Text="Имя:" TextColor="#88FFFFFF" FontSize="14" WidthRequest="60"/>
                        <Label x:Name="NameLabel" TextColor="White" FontSize="16" FontAttributes="Bold"/>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="10">
                        <Label Text="Логин:" TextColor="#88FFFFFF" FontSize="14" WidthRequest="60"/>
                        <Label x:Name="LoginLabel" TextColor="White" FontSize="16"/>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="10">
                        <Label Text="Email:" TextColor="#88FFFFFF" FontSize="14" WidthRequest="60"/>
                        <Label x:Name="EmailLabel" TextColor="White" FontSize="16"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Button Text="ВЫЙТИ ИЗ АККАУНТА" 
                    Clicked="OnLogoutClicked"
                    BackgroundColor="#40FF0000" 
                    TextColor="White" 
                    FontAttributes="Bold" 
                    CornerRadius="25" 
                    HeightRequest="55" 
                    Margin="0,20,0,0"/>

        </VerticalStackLayout>

        <ImageButton Source="back_icon.png" HorizontalOptions="Start" VerticalOptions="Start" 
                     Margin="15, 30, 0, 0" HeightRequest="1" WidthRequest="1" Clicked="OnBackClicked"/>
    </Grid>
</ContentPage>