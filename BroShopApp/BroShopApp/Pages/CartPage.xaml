<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BroShopApp.Pages.CartPage"
             Title="CartPage">
    
    <Grid RowDefinitions="Auto, *, Auto">
        <Label Grid.Row="0" Text="КОРЗИНА" TextColor="White" HorizontalOptions="Center" Margin="0,20" FontAttributes="Bold" FontSize="20"/>

        <CollectionView Grid.Row="1" x:Name="CartCollection" Margin="20,0">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="80, *, Auto" Margin="0,10">
                        <Image Source="{Binding Image}" Aspect="AspectFill" HeightRequest="80" WidthRequest="80"/>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Margin="15,0">
                            <Label Text="{Binding ProductName}" TextColor="White" FontAttributes="Bold"/>
                            <Label Text="{Binding Size, StringFormat='Размер: {0}'}" TextColor="Gray"/>
                            <Label Text="{Binding Price, StringFormat='{0:N0} ₽'}" TextColor="White"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="{Binding Quantity, StringFormat='x{0}'}" TextColor="White" VerticalOptions="Center"/>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Grid.Row="2" Text="ОФОРМИТЬ ЗАКАЗ" Margin="20" BackgroundColor="White" TextColor="Black" CornerRadius="25"/>
    </Grid>
</ContentPage>