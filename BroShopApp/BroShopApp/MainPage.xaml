<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:BroShopApp.Model"
             x:Class="BroShopApp.MainPage"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="Black">

    <ContentPage.Resources>
        <Style x:Key="FilterBtnStyle" TargetType="Button">
            <Setter Property="BackgroundColor" Value="#20FFFFFF"/>
            <Setter Property="TextColor" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HeightRequest" Value="38"/>
            <Setter Property="BorderColor" Value="#40FFFFFF"/>
            <Setter Property="BorderWidth" Value="1"/>
        </Style>
    </ContentPage.Resources>

    <Grid>
        <Image Source="background.jpg" Aspect="AspectFill" />

        <Grid RowDefinitions="Auto, Auto, Auto, *, Auto" Margin="10,0,10,0">

            <Grid Grid.Row="0" ColumnDefinitions="50, *, 50" Padding="5,0,5,0">
                <Image Grid.Column="1" Source="bros_logo_white.png" HeightRequest="90" HorizontalOptions="Center"/>
            </Grid>

            <Border Grid.Row="1" StrokeShape="RoundRectangle 25" Stroke="#30FFFFFF" 
                    BackgroundColor="#15FFFFFF" HeightRequest="50" Margin="0,0,0,15">
                <SearchBar x:Name="productSearchBar" Placeholder="Поиск..." 
                           PlaceholderColor="#70FFFFFF" TextColor="White" 
                           VerticalOptions="Center" TextChanged="OnSearchTextChanged" />
            </Border>

            <ScrollView Grid.Row="2" Orientation="Horizontal" HorizontalScrollBarVisibility="Never" Margin="0,0,0,15">
                <HorizontalStackLayout Spacing="8">
                    <Button Text="Бренды" Clicked="OnBrandFilterClicked" Style="{StaticResource FilterBtnStyle}"/>
                    <Button Text="Типы" Clicked="OnTypeFilterClicked" Style="{StaticResource FilterBtnStyle}"/>
                    <Button Text="Цена ↑" Clicked="OnSortPriceAscClicked" Style="{StaticResource FilterBtnStyle}"/>
                    <Button Text="Цена ↓" Clicked="OnSortPriceDescClicked" Style="{StaticResource FilterBtnStyle}"/>
                </HorizontalStackLayout>
            </ScrollView>

            <CollectionView x:Name="ProductsCollection" Grid.Row="3" VerticalScrollBarVisibility="Never" Margin="0,0,0,10">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="2" HorizontalItemSpacing="12" VerticalItemSpacing="12"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Product">
                        <Border StrokeShape="RoundRectangle 18" Stroke="Transparent" HeightRequest="250">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnProductTapped" CommandParameter="{Binding .}"/>
                            </Border.GestureRecognizers>
                            <Grid>
                                <Image Source="{Binding ImageUrl}" Aspect="AspectFill" />
                                <BoxView VerticalOptions="End" HeightRequest="100">
                                    <BoxView.Background>
                                        <LinearGradientBrush EndPoint="0,1">
                                            <GradientStop Color="Transparent" Offset="0.1" />
                                            <GradientStop Color="#CC000000" Offset="1.0" />
                                        </LinearGradientBrush>
                                    </BoxView.Background>
                                </BoxView>
                                <VerticalStackLayout VerticalOptions="End" Padding="12" Spacing="2">
                                    <Label Text="{Binding Brand.Name}" TextColor="#BBFFFFFF" FontSize="10" FontAttributes="Bold" TextTransform="Uppercase"/>
                                    <Label Text="{Binding Name}" TextColor="White" FontSize="14" FontAttributes="Bold" LineBreakMode="TailTruncation"/>
                                    <Grid ColumnDefinitions="*, Auto" Margin="0,4,0,0">
                                        <Label Grid.Column="0" Text="{Binding Price, StringFormat='{0:N0} ₽'}" TextColor="White" FontSize="16" FontAttributes="Bold" VerticalOptions="Center"/>
                                        <Border Grid.Column="1" StrokeShape="RoundRectangle 8" BackgroundColor="White" HeightRequest="28" WidthRequest="28">
                                            <Label Text="+" TextColor="Black" HorizontalOptions="Center" VerticalOptions="Center" FontAttributes="Bold"/>
                                        </Border>
                                    </Grid>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Border Grid.Row="4" 
                    Margin="0,5,0,10" 
                    HeightRequest="50"
                    StrokeShape="RoundRectangle 25"
                    Stroke="#30FFFFFF"
                    BackgroundColor="#1AFFFFFF">

                <Grid ColumnDefinitions="*, *, 1.2*, *, *">
                    <ImageButton Grid.Column="0" Source="home_icon.png" Margin="12" WidthRequest="24"
                                 BackgroundColor="Transparent" Clicked="OnHomeClicked"/>
                    <ImageButton Grid.Column="1" Source="menu_icon.png" Margin="11" WidthRequest="24"
                                 BackgroundColor="Transparent" Clicked="OnMenuClicked"/>
                    <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" Spacing="2">
                        <Label x:Name="UserStatusLabel" TextColor="White" 
                               FontSize="15" FontAttributes="Bold" HorizontalOptions="Center"/>
                        <VerticalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnProfileClicked"/>
                        </VerticalStackLayout.GestureRecognizers>
                    </VerticalStackLayout>
                    <ImageButton Grid.Column="3" Source="cart_icon.png" Margin="10"
                                 BackgroundColor="Transparent" Clicked="OnCartClicked"/>
                    <ImageButton Grid.Column="4" Source="user_icon.png" Margin="8"
                                 BackgroundColor="Transparent" Clicked="OnProfileClicked"/>
                </Grid>
            </Border>

        </Grid>
    </Grid>
</ContentPage>